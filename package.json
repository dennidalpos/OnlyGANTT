{
  "name": "onlygantt",
  "version": "1.0.0",
  "description": "OnlyGANTT - Interactive Gantt chart application with multi-user locking",
  "main": "src/server/server.js",
  "scripts": {
    "bootstrap": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/bootstrap.ps1",
    "doctor": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/doctor.ps1",
    "compile": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/compile.ps1",
    "build": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/build.ps1",
    "test": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/test.ps1",
    "pack": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/pack.ps1",
    "publish": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/publish.ps1",
    "clean": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/clean.ps1",
    "prestart": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/compile.ps1",
    "start": "node src/server/server.js",
    "service:install": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/windows/service.ps1 -Action Install",
    "service:uninstall": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/windows/service.ps1 -Action Uninstall",
    "service:start": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/windows/service.ps1 -Action Start",
    "service:stop": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/windows/service.ps1 -Action Stop",
    "service:cleanup": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/windows/service.ps1 -Action Cleanup"
  },
  "keywords": [
    "gantt",
    "project-management"
  ],
  "author": "Danny Perondi",
  "license": "UNLICENSED",
  "dependencies": {
    "express": "^4.18.2",
    "ldapts": "^8.1.7",
    "multer": "^2.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "esbuild": "0.27.4"
  }
}
