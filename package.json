{
  "name": "onlygantt",
  "version": "1.0.0",
  "description": "OnlyGANTT - Interactive Gantt chart application with multi-user locking",
  "main": "src/server/server.js",
  "scripts": {
    "bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bootstrap.ps1",
    "doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/doctor.ps1",
    "compile": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/compile.ps1",
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build.ps1",
    "test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test.ps1",
    "pack": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pack.ps1",
    "publish": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish.ps1",
    "clean": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean.ps1",
    "prestart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/compile.ps1",
    "start": "node src/server/server.js",
    "service:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/install-service.ps1",
    "service:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/uninstall-service.ps1",
    "service:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/start-service.ps1",
    "service:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/stop-service.ps1",
    "service:cleanup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/services-cleanup.ps1"
  },
  "keywords": [
    "gantt",
    "project-management"
  ],
  "author": "Danny Perondi",
  "license": "UNLICENSED",
  "dependencies": {
    "express": "^4.18.2",
    "ldapts": "^8.1.7",
    "multer": "^2.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "esbuild": "0.27.4"
  }
}
